{
  "$schema": "../../../schemas/client-runtime-config.schema.json",
  "version": "2.0.0",
  "publishedAt": "2026-06-22T00:00:00Z",
  "client": {
    "key": "cubes",
    "displayName": "Cubes",
    "shortName": "CUBES",
    "environment": "testing"
