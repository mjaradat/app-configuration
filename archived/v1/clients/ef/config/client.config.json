    "maintenanceMode": false,
    "minimumSupportedAppVersion": "1.0.0",
    "forceUpdate": false,
    "timezone": "Asia/Amman",
    "dateFormat": "dd/MM/yyyy",
    "timeFormat": "HH:mm"
  },
  "uploads": {
    "maxFileSizeMb": 25,
    "allowedExtensions": [
      "pdf",
      "png",
      "jpg",
      "jpeg",
      "docx",
      "xlsx"
    ]
  },
  "support": {
    "supportEmail": "support@example.com",
