  "app": {
    "defaultLanguage": "ar",
    "supportedLanguages": [
      "en",
      "ar"
    ],
    "defaultDirection": "rtl",
    "defaultTheme": "light",
    "allowUserThemeSwitch": true,
    "allowUserLanguageSwitch": true,
    "requestTimeoutMs": 30000,
    "firstScreen": "client-runtime-config",
    "secondScreen": "configuration-page"
  },
  "startupFlow": {
