{
  "$schema": "../../../schemas/client-runtime-config.schema.json",
  "version": "1.1.0",
  "publishedAt": "2026-05-18T22:26:08.199793+00:00",
  "client": {
    "key": "ef",
    "displayName": "EF Appraisals",
    "shortName": "EF",
    "environment": "qc"
