      "healthCheckUrl": "https://qc02.cubescpm.com/AuditManagement/BE/api"
    }
  },
  "modules": {
    "audit": {
      "enabled": true,
      "displayName": {
        "en": "Audit",
        "ar": "التدقيق"
      },
      "apiKey": "audit",
      "apiBaseUrlRef": "apis.audit.apiBaseUrl",
      "requiresLicense": true
