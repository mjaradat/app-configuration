    "secondScreen": "configuration-page",
    "showClientRuntimeConfigBeforeConfigurationPage": true,
    "allowSkipClientKey": true,
    "navigateToConfigurationPageWhenSkipped": true,
    "navigateToConfigurationPageWhenClientConfigLoaded": true,
    "doNotBlockAppWhenClientConfigFails": true
  },
