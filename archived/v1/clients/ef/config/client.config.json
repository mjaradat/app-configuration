    "policies": {
      "enabled": false,
      "displayName": {
        "en": "Policies",
        "ar": "السياسات"
      },
      "requiresLicense": true
    },
    "projects": {
      "enabled": true,
      "displayName": {
        "en": "Projects",
        "ar": "المشاريع"
      },
      "requiresLicense": false
    },
    "riskManagement": {
      "enabled": false,
      "displayName": {
        "en": "Risk Management",
        "ar": "إدارة المخاطر"
      },
      "requiresLicense": true
    }
  },
  "license": {
    "enabled": true,
    "licenseId": "ef-qc-license",
    "publicLicenseKey": "EF-QC-PUBLIC-LICENSE-KEY-NOT-SECRET",
    "mode": "test",
    "validationStrategy": "server-side",
    "allowedModules": [
      "audit",
      "projects"
    ],
    "expiresAt": null,
    "note": "This is public test metadata only. Do not put real private license secrets in public Cloudflare config."
  },
  "features": {
    "offlineMode": false,
    "rememberClientKey": true,
    "allowChangeClientKey": true,
    "showClientNameInHeader": true,
    "showClientLogoOnLogin": true,
    "showModuleCards": true
  },
